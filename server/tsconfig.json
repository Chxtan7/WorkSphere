{
  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "paths": {
      "@modules/*": [
        "./src/Modules/*"
      ],
      "@config/*": [
        "./src/Config/*"
      ],
      "@core/*": [
        "./src/Core/*"
      ],
      "@middleware/*": [
        "./src/Middleware/*"
      ],
      "@infra/*": [
        "./src/Infrastructure/*"
      ],
      "@shared/*": [
        "./src/Shared/*"
      ],
      "@types/*" : [
        "./src/Types/*"
      ],
      "@database/*" : [
        "./src/Database/*"
      ]
    },

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "sourceMap": true,
    "removeComments": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": [
      "node"
    ]
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}